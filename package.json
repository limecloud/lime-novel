    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^39.8.5",
    "electron-vite": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
