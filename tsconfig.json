{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@lime-novel/shared-kernel": ["packages/shared-kernel/src/index.ts"],
      "@lime-novel/domain-novel": ["packages/domain-novel/src/index.ts"],
      "@lime-novel/application": ["packages/application/src/index.ts"],
      "@lime-novel/agent-runtime": ["packages/agent-runtime/src/index.ts"],
      "@lime-novel/infrastructure": ["packages/infrastructure/src/index.ts"],
      "@renderer/*": ["apps/desktop/src/renderer/src/*"]
    }
  },
  "include": [
    "electron.vite.config.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts"
  ]
}

